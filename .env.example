# =============================================================================
# Telemon Configuration — Example File
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot Credentials (REQUIRED)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"
TELEGRAM_CHAT_ID="123456789"

# -----------------------------------------------------------------------------
# Server Identity
# -----------------------------------------------------------------------------
SERVER_LABEL="production-01"

# -----------------------------------------------------------------------------
# Alert Channels (Telegram is primary; webhook and email are optional)
# -----------------------------------------------------------------------------
WEBHOOK_URL=""
EMAIL_TO=""
EMAIL_FROM=""
ESCALATION_WEBHOOK_URL=""
ESCALATION_AFTER_MIN=30

# SMTP settings (only needed if using native SMTP email)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASS="your-password"
# SMTP_TLS="yes"

# -----------------------------------------------------------------------------
# Core System Checks
# -----------------------------------------------------------------------------
ENABLE_CPU_CHECK=true
ENABLE_MEMORY_CHECK=true
ENABLE_DISK_CHECK=true
ENABLE_SWAP_CHECK=true
ENABLE_IOWAIT_CHECK=true
ENABLE_ZOMBIE_CHECK=true
ENABLE_INTERNET_CHECK=true
ENABLE_SYSTEM_PROCESSES=true
ENABLE_FAILED_SYSTEMD_SERVICES=true

# -----------------------------------------------------------------------------
# Thresholds
# -----------------------------------------------------------------------------
CPU_THRESHOLD_WARN=70
CPU_THRESHOLD_CRIT=80

MEM_THRESHOLD_WARN=15
MEM_THRESHOLD_CRIT=10

DISK_THRESHOLD_WARN=85
DISK_THRESHOLD_CRIT=95

SWAP_THRESHOLD_WARN=50
SWAP_THRESHOLD_CRIT=80

IOWAIT_THRESHOLD_WARN=30
IOWAIT_THRESHOLD_CRIT=50

ZOMBIE_THRESHOLD_WARN=5
ZOMBIE_THRESHOLD_CRIT=20

PING_FAIL_THRESHOLD=3
PING_TARGET="8.8.8.8"

# -----------------------------------------------------------------------------
# Critical System Processes
# -----------------------------------------------------------------------------
CRITICAL_SYSTEM_PROCESSES="sshd"

# -----------------------------------------------------------------------------
# Auto-Remediation (automatically restart failed services)
# -----------------------------------------------------------------------------
AUTO_RESTART_SERVICES=""

# -----------------------------------------------------------------------------
# Extended Hardware Monitoring
# -----------------------------------------------------------------------------
ENABLE_NVME_CHECK=false
NVME_DEVICE="/dev/nvme0n1"
NVME_TEMP_THRESHOLD_WARN=70
NVME_TEMP_THRESHOLD_CRIT=80

ENABLE_TEMP_CHECK=false
TEMP_THRESHOLD_WARN=75
TEMP_THRESHOLD_CRIT=90

ENABLE_NETWORK_CHECK=false
NETWORK_INTERFACE=""
NETWORK_THRESHOLD_WARN=800
NETWORK_THRESHOLD_CRIT=950

ENABLE_GPU_CHECK=false
GPU_TEMP_THRESHOLD_WARN=80
GPU_TEMP_THRESHOLD_CRIT=95

ENABLE_TCP_PORT_CHECK=false
CRITICAL_PORTS="localhost:22"

# -----------------------------------------------------------------------------
# Service Monitoring
# -----------------------------------------------------------------------------
ENABLE_DOCKER_CONTAINERS=false
CRITICAL_CONTAINERS=""

ENABLE_PM2_PROCESSES=false
CRITICAL_PM2_PROCESSES=""

# -----------------------------------------------------------------------------
# Website & DNS Monitoring
# -----------------------------------------------------------------------------
ENABLE_SITE_MONITOR=false
CRITICAL_SITES=""
SITE_EXPECTED_STATUS=200
SITE_MAX_RESPONSE_MS=10000
SITE_CHECK_SSL=false
SITE_SSL_WARN_DAYS=7
SITE_ALLOW_INTERNAL=false

ENABLE_DNS_CHECK=false
DNS_CHECK_DOMAIN="example.com"

ENABLE_DNS_RECORD_CHECK=false
DNS_CHECK_RECORDS=""

# -----------------------------------------------------------------------------
# Proxmox VE Monitoring
# -----------------------------------------------------------------------------
ENABLE_PROXMOX_GUESTS=false
ENABLE_PROXMOX_STORAGE=false
ENABLE_PROXMOX_CLUSTER=false
ENABLE_PROXMOX_TASKS=false
PROXMOX_STORAGE_WARN=85
PROXMOX_STORAGE_CRIT=95
# Task thresholds: warn at 1+ failed tasks, crit at 1+ (0 = OK, never warn)
PROXMOX_TASK_WARN=1
PROXMOX_TASK_CRIT=1
PROXMOX_TASK_MINUTES=60

# -----------------------------------------------------------------------------
# Log, Integrity & Drift Monitoring
# -----------------------------------------------------------------------------
ENABLE_LOG_CHECK=false
LOG_WATCH_FILES="/var/log/syslog"
LOG_WATCH_PATTERNS="OOM|error|panic|fatal"
LOG_WATCH_LINES=100

ENABLE_INTEGRITY_CHECK=false
INTEGRITY_WATCH_FILES=""

ENABLE_DRIFT_DETECTION=false
DRIFT_WATCH_FILES=""
DRIFT_IGNORE_PATTERN="^[+-]?\s*#"
DRIFT_MAX_DIFF_LINES=20
DRIFT_SENSITIVE_FILES=""

# -----------------------------------------------------------------------------
# Plugins
# -----------------------------------------------------------------------------
ENABLE_PLUGINS=false
CHECKS_DIR="/opt/telemon/checks.d"

# -----------------------------------------------------------------------------
# Database Checks
# -----------------------------------------------------------------------------
ENABLE_DATABASE_CHECKS=false
ENABLE_ODBC_CHECKS=false

# -----------------------------------------------------------------------------
# Predictive Resource Alerts
# -----------------------------------------------------------------------------
ENABLE_PREDICTIVE_ALERTS=false
PREDICT_HORIZON_HOURS=24
PREDICT_DATAPOINTS=48
PREDICT_MIN_DATAPOINTS=12

# -----------------------------------------------------------------------------
# Fleet & Heartbeat Monitoring
# -----------------------------------------------------------------------------
ENABLE_HEARTBEAT=false
HEARTBEAT_MODE="file"
HEARTBEAT_DIR="/var/lib/telemon/heartbeats"

ENABLE_FLEET_CHECK=false
FLEET_HEARTBEAT_DIR="/var/lib/telemon/heartbeats"
FLEET_STALE_THRESHOLD_MIN=15
FLEET_CRITICAL_MULTIPLIER=2

ENABLE_CRON_CHECK=false
CRON_WATCH_JOBS=""

# -----------------------------------------------------------------------------
# Exports & Integrations
# -----------------------------------------------------------------------------
ENABLE_PROMETHEUS_EXPORT=false
PROMETHEUS_TEXTFILE_DIR="/var/lib/node_exporter/textfile_collector"

ENABLE_JSON_STATUS=false
JSON_STATUS_FILE="/var/lib/telemon/status.json"

STATUS_PAGE_FILE="/var/www/telemon-status.html"
STATUS_PAGE_AUTO_REFRESH=false
STATUS_PAGE_REFRESH_SEC=60

# -----------------------------------------------------------------------------
# Audit Logging
# -----------------------------------------------------------------------------
ENABLE_AUDIT_LOGGING=false
AUDIT_LOG_FILE="/var/log/telemon_audit.log"
AUDIT_EVENTS="all"

# -----------------------------------------------------------------------------
# Alert Tuning
# -----------------------------------------------------------------------------
CONFIRMATION_COUNT=3
ALERT_COOLDOWN_SEC=900
TOP_PROCESS_COUNT=5
CHECK_TIMEOUT=30

# -----------------------------------------------------------------------------
# Maintenance Windows
# -----------------------------------------------------------------------------
MAINT_SCHEDULE=""

# -----------------------------------------------------------------------------
# State & Log Files
# -----------------------------------------------------------------------------
STATE_FILE="/var/lib/telemon/state"
LOG_FILE="/var/log/telemon.log"
LOG_LEVEL="INFO"
LOG_MAX_SIZE_MB=10
LOG_MAX_BACKUPS=5

MAX_ALERT_QUEUE_SIZE="1048576"
MAX_ALERT_QUEUE_AGE="86400"

BACKUP_KEEP_COUNT=10
