# =============================================================================
# Telemon - Configuration
# =============================================================================
# See README.md for detailed setup instructions

# -----------------------------------------------------------------------------
# Telegram Bot Credentials (REQUIRED)
# -----------------------------------------------------------------------------
# 1. Message @BotFather on Telegram, send /newbot, follow instructions
# 2. Copy the bot token (looks like: 123456789:ABCdefGHIjklMNOpqrSTUvwxyz)
# 3. Message @userinfobot to get your chat ID (or use getUpdates API)
# 4. Test: curl -X POST "https://api.telegram.org/bot<TOKEN>/sendMessage" \
#           -d "chat_id=<CHAT_ID>" -d "text=Test"
#
# Full guide: https://github.com/SwordfishTrumpet/telemon#step-1-create-a-bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="your-bot-token-here"
TELEGRAM_CHAT_ID="your-chat-id-here"

# -----------------------------------------------------------------------------
# Additional Alert Channels (all optional)
# -----------------------------------------------------------------------------
# Generic webhook — POST JSON payload to any URL (Slack, Discord, ntfy, n8n, etc.)
# WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"
WEBHOOK_URL=""

# Email alerts — requires sendmail or msmtp to be installed
# EMAIL_TO="admin@example.com"
EMAIL_TO=""
# Sender address for email alerts (defaults to telemon@$(hostname) if empty)
EMAIL_FROM=""

# Alert escalation — sends to a different channel if alert stays unresolved
# ESCALATION_WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"
# ESCALATION_AFTER_MIN=30
ESCALATION_WEBHOOK_URL=""
ESCALATION_AFTER_MIN=30

# -----------------------------------------------------------------------------
# Check Enable/Disable
# Set to "true" to enable, "false" to disable each check
# -----------------------------------------------------------------------------
# Core system checks (safe on all Linux systems)
ENABLE_CPU_CHECK=true
ENABLE_MEMORY_CHECK=true
ENABLE_DISK_CHECK=true
ENABLE_SWAP_CHECK=true
ENABLE_IOWAIT_CHECK=true
ENABLE_ZOMBIE_CHECK=true
ENABLE_INTERNET_CHECK=true

# Process/service checks (disable if not using these tools)
ENABLE_SYSTEM_PROCESSES=true
ENABLE_FAILED_SYSTEMD_SERVICES=true   # Set to false on non-systemd systems (Alpine, etc.)
ENABLE_DOCKER_CONTAINERS=false        # Enable if you use Docker
ENABLE_PM2_PROCESSES=false            # Enable if you use PM2
ENABLE_SITE_MONITOR=false             # Enable and configure URLs below
ENABLE_NVME_CHECK=false               # Enable NVMe/SMART health check (requires smartctl)

# Extended monitoring checks (all default to false)
ENABLE_TCP_PORT_CHECK=false           # TCP port reachability
ENABLE_TEMP_CHECK=false               # CPU temperature (requires lm-sensors)
ENABLE_DNS_CHECK=false                # DNS resolution health
ENABLE_GPU_CHECK=false                # GPU usage/temperature (requires nvidia-smi)
ENABLE_UPS_CHECK=false                # Battery/UPS status (upower or apcaccess)
ENABLE_NETWORK_CHECK=false            # Network bandwidth monitoring
ENABLE_LOG_CHECK=false                # Log pattern matching
ENABLE_INTEGRITY_CHECK=false          # File/directory integrity (checksums)
ENABLE_CRON_CHECK=false               # Cron job completion tracking

# Export / integration
ENABLE_PROMETHEUS_EXPORT=false        # Prometheus textfile export
ENABLE_JSON_STATUS=false              # JSON status file output

# Fleet / heartbeat monitoring (see detailed config below)
ENABLE_HEARTBEAT=false                # Dead-man's-switch heartbeat sender
ENABLE_FLEET_CHECK=false              # Monitor sibling server heartbeats

# -----------------------------------------------------------------------------
# Thresholds
# -----------------------------------------------------------------------------
# CPU: alert if 1-min load average exceeds this % of available cores
CPU_THRESHOLD_WARN=70
CPU_THRESHOLD_CRIT=80

# Memory: alert if FREE memory drops below this % of total
MEM_THRESHOLD_WARN=15
MEM_THRESHOLD_CRIT=10

# Disk: alert if any partition exceeds this % usage
DISK_THRESHOLD_WARN=85
DISK_THRESHOLD_CRIT=90

# Swap: alert if swap usage exceeds this % of total swap
# Note: If system has no swap, this check will silently pass
SWAP_THRESHOLD_WARN=50
SWAP_THRESHOLD_CRIT=80

# I/O Wait: alert if CPU time spent waiting for I/O exceeds this %
IOWAIT_THRESHOLD_WARN=30
IOWAIT_THRESHOLD_CRIT=50

# Zombie processes: alert if zombie count exceeds this number
ZOMBIE_THRESHOLD_WARN=5
ZOMBIE_THRESHOLD_CRIT=20

# Internet: how many consecutive ping failures before alerting
PING_FAIL_THRESHOLD=3
PING_TARGET="8.8.8.8"

# CPU temperature thresholds (°C) — used with ENABLE_TEMP_CHECK
TEMP_THRESHOLD_WARN=75
TEMP_THRESHOLD_CRIT=90

# GPU temperature thresholds (°C) — used with ENABLE_GPU_CHECK
GPU_TEMP_THRESHOLD_WARN=80
GPU_TEMP_THRESHOLD_CRIT=95

# Network bandwidth thresholds (Mbit/s) — used with ENABLE_NETWORK_CHECK
NETWORK_THRESHOLD_WARN=800
NETWORK_THRESHOLD_CRIT=950

# Battery/UPS charge thresholds (%) — used with ENABLE_UPS_CHECK
# Inverted: lower is worse
UPS_THRESHOLD_WARN=30
UPS_THRESHOLD_CRIT=10

# -----------------------------------------------------------------------------
# Confirmation Count
# How many consecutive checks must show the same state before alerting.
# Prevents false alarms from transient spikes. Set to 1 for immediate alerts.
# Example: With CONFIRMATION_COUNT=3 and 5-min cron, a spike must last 15 min.
# -----------------------------------------------------------------------------
CONFIRMATION_COUNT=3

# -----------------------------------------------------------------------------
# Check Timeout
# Maximum time (in seconds) allowed for each external command.
# Prevents hangs from docker, systemctl, or pm2 commands.
# Should be less than your cron interval (default: 30s for 5-min cron).
# -----------------------------------------------------------------------------
CHECK_TIMEOUT=30

# -----------------------------------------------------------------------------
# Alert Rate Limiting
# Minimum seconds between alerts for the same check key.
# Prevents alert floods when a check flaps (OK→CRIT→OK→CRIT).
# Set to 0 to disable rate limiting. Default: 900 (15 minutes).
# -----------------------------------------------------------------------------
ALERT_COOLDOWN_SEC=900

# -----------------------------------------------------------------------------
# Top Process Count
# Number of top CPU/memory processes to include in alert details
# when CPU or memory is in WARNING/CRITICAL state.
# -----------------------------------------------------------------------------
TOP_PROCESS_COUNT=5

# -----------------------------------------------------------------------------
# Critical Processes (system-level)
# These are checked via `pgrep` or `systemctl`
# Space-separated list of process names - empty string disables this check
# Common examples: "sshd", "cron", "nginx", "apache2"
# -----------------------------------------------------------------------------
CRITICAL_SYSTEM_PROCESSES="sshd"

# -----------------------------------------------------------------------------
# Auto-Remediation
# Space-separated list of services to automatically restart on failure
# Requires systemd. On detected failure, runs systemctl restart <service>.
# Example: AUTO_RESTART_SERVICES="nginx sshd"
# -----------------------------------------------------------------------------
AUTO_RESTART_SERVICES=""

# -----------------------------------------------------------------------------
# Critical Docker Containers
# These are checked via `docker ps` — use container NAMES, not image names.
# Find your container names with: docker ps --format '{{.Names}}'
# Space-separated list - empty string disables this check
# Example: "redis nginx myapp"
# -----------------------------------------------------------------------------
CRITICAL_CONTAINERS=""

# -----------------------------------------------------------------------------
# Critical PM2 Processes
# These are checked via `pm2 jlist`
# Space-separated list of PM2 process names - empty string disables this check
# Example: "app worker api"
# -----------------------------------------------------------------------------
CRITICAL_PM2_PROCESSES=""

# -----------------------------------------------------------------------------
# Site/Website Monitoring
# Monitors HTTP/HTTPS endpoints for availability and SSL certificate health
# -----------------------------------------------------------------------------
# Space-separated list of URLs to monitor - empty string disables this check
# Format: URL or URL|param1=value1|param2=value2
# Examples:
#   CRITICAL_SITES="https://example.com"
#   CRITICAL_SITES="https://api.example.com|expected_status=200|max_response_ms=3000"
#   CRITICAL_SITES="https://example.com https://api.example.com|max_response_ms=5000|check_ssl=true"
CRITICAL_SITES=""

# Default expected HTTP status code (used when not specified per-site)
SITE_EXPECTED_STATUS=200

# Default maximum response time in milliseconds (used when not specified per-site)
SITE_MAX_RESPONSE_MS=10000

# Enable SSL certificate expiry checking (true/false)
SITE_CHECK_SSL=false

# Days before SSL expiry to trigger warning
SITE_SSL_WARN_DAYS=7

# NVMe device to monitor (used by ENABLE_NVME_CHECK)
# Run `lsblk -d -o NAME,TYPE | grep disk` to find your NVMe device
NVME_DEVICE="/dev/nvme0n1"

# NVMe temperature thresholds (°C) — used with ENABLE_NVME_CHECK
NVME_TEMP_THRESHOLD_WARN=70
NVME_TEMP_THRESHOLD_CRIT=80

# -----------------------------------------------------------------------------
# TCP Port Checks
# Space-separated list of host:port pairs to check
# Example: CRITICAL_PORTS="localhost:22 192.168.1.1:443 db-server:5432"
# -----------------------------------------------------------------------------
CRITICAL_PORTS=""

# -----------------------------------------------------------------------------
# DNS Resolution Health
# Domain to resolve for health checking
# -----------------------------------------------------------------------------
DNS_CHECK_DOMAIN="example.com"

# -----------------------------------------------------------------------------
# Network Bandwidth Monitoring
# Auto-detects primary interface if not set
# NETWORK_INTERFACE="eth0"
# -----------------------------------------------------------------------------
NETWORK_INTERFACE=""

# -----------------------------------------------------------------------------
# Log Pattern Matching
# Space-separated list of log files and regex patterns to watch
# -----------------------------------------------------------------------------
LOG_WATCH_FILES=""
LOG_WATCH_PATTERNS=""
LOG_WATCH_LINES=100

# -----------------------------------------------------------------------------
# File/Directory Integrity Monitoring
# Space-separated list of files to checksum-monitor
# Example: INTEGRITY_WATCH_FILES="/etc/passwd /etc/shadow /etc/ssh/sshd_config"
# -----------------------------------------------------------------------------
INTEGRITY_WATCH_FILES=""

# -----------------------------------------------------------------------------
# Cron Job Completion Tracking
# Space-separated list of job entries: name:touchfile:max_age_minutes
# Each cron job should touch its heartbeat file on completion.
# Example: CRON_WATCH_JOBS="backup:/tmp/backup_heartbeat:1440 report:/tmp/report_heartbeat:60"
# -----------------------------------------------------------------------------
CRON_WATCH_JOBS=""

# -----------------------------------------------------------------------------
# Maintenance Windows
# Flag file: touch /tmp/telemon_maint to silence alerts during planned work
# Remove it when done: rm /tmp/telemon_maint
# -----------------------------------------------------------------------------
MAINT_FLAG_FILE="/tmp/telemon_maint"

# Scheduled maintenance windows (semicolon-separated)
# Format: "Day HH:MM-HH:MM;Day HH:MM-HH:MM"
# Example: MAINT_SCHEDULE="Sun 02:00-04:00;Sat 03:00-05:00"
MAINT_SCHEDULE=""

# -----------------------------------------------------------------------------
# Prometheus Textfile Export
# Writes metrics to a file for node_exporter --collector.textfile to scrape
# No HTTP server, no persistent process.
# -----------------------------------------------------------------------------
PROMETHEUS_TEXTFILE_DIR="/var/lib/node_exporter/textfile_collector"

# -----------------------------------------------------------------------------
# JSON Status File
# Writes current state to JSON after each run for lightweight status API
# Serve with nginx/caddy for a status endpoint.
# -----------------------------------------------------------------------------
JSON_STATUS_FILE="/tmp/telemon_status.json"

# -----------------------------------------------------------------------------
# Heartbeat / Fleet Monitoring
# Dead-man's-switch heartbeat: proves Telemon is still running.
# Fleet monitoring: detects when sibling Telemon instances go silent.
# -----------------------------------------------------------------------------
# Server identity — used in alert headers, heartbeat files, fleet monitoring
# Defaults to $(hostname) if empty or unset.
# SERVER_LABEL="web-prod-01"
SERVER_LABEL=""

# Enable heartbeat sending (dead-man's-switch)
ENABLE_HEARTBEAT=false

# Heartbeat mode: "file" (local/NFS) or "webhook" (HTTP ping)
# NOTE: Fleet monitoring (ENABLE_FLEET_CHECK) requires "file" mode on sender nodes.
# Webhook mode only pings an external service — it does not write files for fleet monitors to read.
HEARTBEAT_MODE="file"

# Directory for heartbeat files (file mode)
# Shared via NFS/mount for fleet monitoring across servers.
# NOTE: Must match FLEET_HEARTBEAT_DIR on fleet monitor instance(s)
# so that heartbeat files written here are visible to the monitor.
HEARTBEAT_DIR="/tmp/telemon_heartbeats"

# URL to ping on each run (webhook mode)
# Supports Healthchecks.io, UptimeRobot, ntfy, or any URL accepting GET requests.
# HEARTBEAT_URL="https://hc-ping.com/your-uuid-here"
HEARTBEAT_URL=""

# Enable fleet heartbeat monitoring (checks sibling servers' heartbeat files)
ENABLE_FLEET_CHECK=false

# Directory to scan for heartbeat files from other servers
# NOTE: Must match HEARTBEAT_DIR on sender instances
# so this monitor can read the heartbeat files they write.
FLEET_HEARTBEAT_DIR="/tmp/telemon_heartbeats"

# Minutes before a stale heartbeat triggers WARNING
FLEET_STALE_THRESHOLD_MIN=15

# CRITICAL at threshold * multiplier (default: 15 * 2 = 30 minutes)
FLEET_CRITICAL_MULTIPLIER=2

# Space-separated list of expected server labels (optional)
# Triggers CRITICAL if a listed server has no heartbeat file at all.
# FLEET_EXPECTED_SERVERS="web-prod-01 db-prod-01 api-staging"
FLEET_EXPECTED_SERVERS=""

# -----------------------------------------------------------------------------
# Predictive Resource Exhaustion
# Tracks metric trends across runs and uses linear regression to predict
# when a resource (disk, memory, swap, inodes) will reach 100%.
# Fires a WARNING alert when exhaustion is projected within the horizon.
# No new dependencies — uses pure Bash + awk.
# -----------------------------------------------------------------------------
ENABLE_PREDICTIVE_ALERTS=false

# Hours into the future to predict — alert if exhaustion is within this window
PREDICT_HORIZON_HOURS=24

# Number of datapoints to retain (1 per run, e.g., 48 = ~4h at 5-min cron)
PREDICT_DATAPOINTS=48

# Minimum datapoints required before prediction activates (must be >= 3)
PREDICT_MIN_DATAPOINTS=12

# -----------------------------------------------------------------------------
# Configuration Drift Detection
# Monitors critical files for unauthorized changes with rich context:
# - Detects content changes (with diff output)
# - Tracks metadata changes (size, permissions, owner)
# - User attribution (who made the change)
# - Ignore patterns for comment-only changes
# -----------------------------------------------------------------------------
ENABLE_DRIFT_DETECTION=false

# Space-separated list of files to monitor (absolute paths)
# Example: DRIFT_WATCH_FILES="/etc/nginx/nginx.conf /etc/ssh/sshd_config /etc/passwd"
DRIFT_WATCH_FILES=""

# Extended regex pattern for diff lines to ignore (e.g., comment-only changes)
# Example: DRIFT_IGNORE_PATTERN="^[+-]?\s*#"  (ignores comment lines)
DRIFT_IGNORE_PATTERN=""

# Maximum diff lines to include in alert (prevents Telegram overflow)
DRIFT_MAX_DIFF_LINES=20

# Space-separated list of sensitive files whose diff should be redacted
# Example: DRIFT_SENSITIVE_FILES="/etc/shadow /etc/gshadow"
DRIFT_SENSITIVE_FILES=""

# -----------------------------------------------------------------------------
# State file for alert deduplication
# -----------------------------------------------------------------------------
STATE_FILE="/tmp/telemon_sys_alert_state"

# Log file path
# Defaults to telemon.log in the script directory if not set.
# Use an absolute path if you want logs elsewhere.
# LOG_FILE="/var/log/telemon.log"
LOG_FILE="${SCRIPT_DIR}/telemon.log"

# Maximum log file size in MB before rotation (default: 10)
LOG_MAX_SIZE_MB=10

# Maximum number of rotated log backups to keep (default: 5)
LOG_MAX_BACKUPS=5

# Log verbosity level (default: INFO)
# Levels: DEBUG (most verbose), INFO, WARN, ERROR (least verbose)
# Set to WARN for quieter production logs, DEBUG for troubleshooting.
# LOG_LEVEL="INFO"

# ---------------------------------------------------------------------------
# Admin / Backup Settings
# ---------------------------------------------------------------------------

# Maximum number of backups to keep (used by telemon-admin.sh backup command).
# Older backups are automatically purged after a successful backup.
# Set to 0 or leave empty to keep all backups.
# BACKUP_KEEP_COUNT=5
