# =============================================================================
# Telemon - Configuration
# =============================================================================
# See README.md for detailed setup instructions

# -----------------------------------------------------------------------------
# Telegram Bot Credentials (REQUIRED)
# -----------------------------------------------------------------------------
# 1. Message @BotFather on Telegram, send /newbot, follow instructions
# 2. Copy the bot token (looks like: 123456789:ABCdefGHIjklMNOpqrSTUvwxyz)
# 3. Message @userinfobot to get your chat ID (or use getUpdates API)
# 4. Test: curl -X POST "https://api.telegram.org/bot<TOKEN>/sendMessage" \
#           -d "chat_id=<CHAT_ID>" -d "text=Test"
#
# Full guide: https://github.com/yourusername/telemon#step-1-create-a-bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="your-bot-token-here"
TELEGRAM_CHAT_ID="your-chat-id-here"

# -----------------------------------------------------------------------------
# Check Enable/Disable
# Set to "true" to enable, "false" to disable each check
# -----------------------------------------------------------------------------
# Core system checks (safe on all Linux systems)
ENABLE_CPU_CHECK=true
ENABLE_MEMORY_CHECK=true
ENABLE_DISK_CHECK=true
ENABLE_SWAP_CHECK=true
ENABLE_IOWAIT_CHECK=true
ENABLE_ZOMBIE_CHECK=true
ENABLE_INTERNET_CHECK=true

# Process/service checks (disable if not using these tools)
ENABLE_SYSTEM_PROCESSES=true
ENABLE_FAILED_SYSTEMD_SERVICES=true   # Set to false on non-systemd systems (Alpine, etc.)
ENABLE_DOCKER_CONTAINERS=false        # Enable if you use Docker
ENABLE_PM2_PROCESSES=false            # Enable if you use PM2
ENABLE_SITE_MONITOR=false             # Enable and configure URLs below
ENABLE_NVME_CHECK=false               # Enable NVMe/SMART health check (requires smartctl)

# -----------------------------------------------------------------------------
# Thresholds
# -----------------------------------------------------------------------------
# CPU: alert if 1-min load average exceeds this % of available cores
CPU_THRESHOLD_WARN=70
CPU_THRESHOLD_CRIT=80

# Memory: alert if FREE memory drops below this % of total
MEM_THRESHOLD_WARN=15
MEM_THRESHOLD_CRIT=10

# Disk: alert if any partition exceeds this % usage
DISK_THRESHOLD_WARN=85
DISK_THRESHOLD_CRIT=90

# Swap: alert if swap usage exceeds this % of total swap
# Note: If system has no swap, this check will silently pass
SWAP_THRESHOLD_WARN=50
SWAP_THRESHOLD_CRIT=80

# I/O Wait: alert if CPU time spent waiting for I/O exceeds this %
IOWAIT_THRESHOLD_WARN=30
IOWAIT_THRESHOLD_CRIT=50

# Zombie processes: alert if zombie count exceeds this number
ZOMBIE_THRESHOLD_WARN=5
ZOMBIE_THRESHOLD_CRIT=20

# Internet: how many consecutive ping failures before alerting
PING_FAIL_THRESHOLD=3
PING_TARGET="8.8.8.8"

# -----------------------------------------------------------------------------
# Confirmation Count
# How many consecutive checks must show the same state before alerting.
# Prevents false alarms from transient spikes. Set to 1 for immediate alerts.
# Example: With CONFIRMATION_COUNT=3 and 5-min cron, a spike must last 15 min.
# -----------------------------------------------------------------------------
CONFIRMATION_COUNT=3

# -----------------------------------------------------------------------------
# Check Timeout
# Maximum time (in seconds) allowed for each external command.
# Prevents hangs from docker, systemctl, or pm2 commands.
# Should be less than your cron interval (default: 30s for 5-min cron).
# -----------------------------------------------------------------------------
CHECK_TIMEOUT=30

# -----------------------------------------------------------------------------
# Critical Processes (system-level)
# These are checked via `pgrep` or `systemctl`
# Space-separated list of process names - empty string disables this check
# Common examples: "sshd", "cron", "nginx", "apache2"
# -----------------------------------------------------------------------------
CRITICAL_SYSTEM_PROCESSES="sshd"

# -----------------------------------------------------------------------------
# Critical Docker Containers
# These are checked via `docker ps`
# Space-separated list of container names - empty string disables this check
# Example: "postgres redis nginx"
# -----------------------------------------------------------------------------
CRITICAL_CONTAINERS=""

# -----------------------------------------------------------------------------
# Critical PM2 Processes
# These are checked via `pm2 jlist`
# Space-separated list of PM2 process names - empty string disables this check
# Example: "app worker api"
# -----------------------------------------------------------------------------
CRITICAL_PM2_PROCESSES=""

# -----------------------------------------------------------------------------
# Site/Website Monitoring
# Monitors HTTP/HTTPS endpoints for availability and SSL certificate health
# -----------------------------------------------------------------------------
# Space-separated list of URLs to monitor - empty string disables this check
# Format: URL or URL|param1=value1|param2=value2
# Examples:
#   CRITICAL_SITES="https://example.com"
#   CRITICAL_SITES="https://api.example.com|expected_status=200|max_response_ms=3000"
#   CRITICAL_SITES="https://example.com https://api.example.com|max_response_ms=5000|check_ssl=true"
CRITICAL_SITES=""

# Default expected HTTP status code (used when not specified per-site)
SITE_EXPECTED_STATUS=200

# Default maximum response time in milliseconds (used when not specified per-site)
SITE_MAX_RESPONSE_MS=10000

# Enable SSL certificate expiry checking (true/false)
SITE_CHECK_SSL=false

# Days before SSL expiry to trigger warning
SITE_SSL_WARN_DAYS=7

# NVMe device to monitor (used by ENABLE_NVME_CHECK)
# Run `lsblk -d -o NAME,TYPE | grep disk` to find your NVMe device
NVME_DEVICE="/dev/nvme0n1"

# -----------------------------------------------------------------------------
# State file for alert deduplication
# -----------------------------------------------------------------------------
STATE_FILE="/tmp/telemon_sys_alert_state"

# Log file (relative to script location or use absolute path)
LOG_FILE="\${SCRIPT_DIR}/telemon.log"
